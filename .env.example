# LumiEdu skeleton environment file
# Fill values in config-ready step.

APP_NAME=LumiEdu
APP_ENV=development

FRONTEND_PORT=3000
API_PORT=8000
PROXY_PORT=80
API_BASE_URL=http://api:8000

POSTGRES_DB=lumiedu
POSTGRES_USER=lumiedu
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lumiedu:change_me@postgres:5432/lumiedu

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

STT_PORT=8101
LLM_PORT=11434
TTS_PORT=8103
STT_URL=http://stt-service:8101
LLM_URL=http://llm-service:8102
TTS_URL=http://tts-service:8103

REQUEST_TIMEOUT_SECONDS=15
STT_TIMEOUT_SECONDS=8
LLM_TIMEOUT_SECONDS=10
TTS_TIMEOUT_SECONDS=8

OLLAMA_MODEL=llama3.2:3b
MAX_CONCURRENT_SESSIONS=3
JWT_SECRET_KEY=change_me_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_DISABLED=false
BOOTSTRAP_ADMIN_EMAIL=admin@lumiedu.local
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
SESSION_CREATE_RATE_LIMIT=20
SESSION_CREATE_RATE_WINDOW_SECONDS=300

# Real-model provider options (empty = fallback to mock)
OLLAMA_BASE_URL=http://host.docker.internal:11434
STT_PROVIDER_URL=
TTS_PROVIDER_URL=
